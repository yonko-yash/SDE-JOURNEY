class Solution {

    public int answer(int arr[],int start , int end , int target){

        if(start>end){
            return -1;
        }
        int mid = start + (end-start)/2;

        if(arr[mid] == target){
            return mid;
        }
        else if(arr[mid]>target){
            
            end = mid-1;
        }
        else if(arr[mid]<target){
            start = mid+1;
        }
        return answer(arr,start,end,target);
    }

    public int search(int[] nums, int target) {
        int start = 0;
        int end = nums.length-1;
        int ans = answer(nums,start,end,target);
        return ans;
    }
}

