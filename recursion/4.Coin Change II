class Solution {

    public int solve(int amount,int index,int[] coins){

        if(amount == 0){
            return 1;
        }

        if(amount<0){
            return 0;
        }
        if(index>=coins.length){
            return 0;
        }

        int include = solve(amount - coins[index],index,coins);
        int exclude = solve(amount,index+1,coins);

        int finalans = include + exclude;
        return finalans;

    }

    public int change(int amount, int[] coins) {
        int index = 0;
        int ans = solve(amount,index,coins);
        return ans;
    }
}


